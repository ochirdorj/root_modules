{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyMarketplaceAMIs",
      "Effect": "Deny",
      "Action": [
          "ec2:RunInstances",
          "ec2:RunScheduledInstances"
      ],
      "Resource": "arn:aws:ec2:*::image/ami-*",
      "Condition": {
        "StringNotEquals": {
          "ec2:Owner": [
            "928167817523",
             "032736242127",
             "417022149422",
             "423452794861",
             "472655909199",
             "627345512452",
             "772200096312",
             "870844658092"
          ]
        }
      }
    }
  ]
}